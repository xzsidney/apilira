datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  role       Role        @default(JOGADOR)
  characters Character[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  @@map("user")
}

enum Role {
  ADMIN
  MESTRE
  JOGADOR
}

enum GameStyle {
  VAMPIRE
  WEREWOLF
  MAGE
  HUNTER
}

model Character {
  id              String                @id @default(uuid())
  name            String
  gameStyle       GameStyle
  experienceTotal Int                   @default(0)
  experienceSpent Int                   @default(0)
  isNpc           Boolean               @default(false)
  isTemplate      Boolean               @default(false)
  userId          String
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  attributes      CharacterAttribute[]
  skills          CharacterSkill[]
  statuses        CharacterStatus[]
  powers          CharacterPower[]
  meritsFlaws     CharacterMeritFlaw[]
  items           CharacterItem[]
  backgrounds     CharacterBackground[]
  havens          CharacterHaven[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  @@map("character")
}

model AttributeDefinition {
  id                  String               @id @default(uuid())
  name                String
  type                String // e.g. "VAMPIRE", "WEREWOLF", "MAGE", "HUNTER"
  description         String?              @db.Text
  characterAttributes CharacterAttribute[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([name, type])
  @@map("attributedefinition")
}

model CharacterAttribute {
  id          String              @id @default(uuid())
  characterId String
  character   Character           @relation(fields: [characterId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   AttributeDefinition @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       Int                 @default(1)
  specialty   String?
  description String?             @db.Text

  @@unique([characterId, attributeId])
  @@map("characterattribute")
}

model SkillDefinition {
  id              String           @id @default(uuid())
  name            String
  type            String // e.g. "VAMPIRE", "WEREWOLF", "MAGE", "HUNTER", "UNIVERSAL"
  description     String?          @db.Text
  characterSkills CharacterSkill[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([name, type])
  @@map("skilldefinition")
}

model CharacterSkill {
  id          String          @id @default(uuid())
  characterId String
  character   Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skillId     String
  skill       SkillDefinition @relation(fields: [skillId], references: [id], onDelete: Cascade)
  value       Int             @default(0)
  specialty   String?
  description String?         @db.Text

  @@unique([characterId, skillId])
  @@map("characterskill")
}

model StatusDefinition {
  id                  String            @id @default(uuid())
  name                String
  gameStyle           String // "VAMPIRE", "WEREWOLF", "MAGE", "HUNTER", "UNIVERSAL"
  maxValue            Int // Maximum value for UI dots/boxes
  defaultInitialValue Int               @default(0) // Default value when a character is created
  description         String?           @db.Text
  characterStatuses   CharacterStatus[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([name, gameStyle])
  @@map("statusdefinition")
}

model CharacterStatus {
  id          String           @id @default(uuid())
  characterId String
  character   Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  statusId    String
  status      StatusDefinition @relation(fields: [statusId], references: [id], onDelete: Cascade)
  value       Int              @default(0)

  @@unique([characterId, statusId])
  @@map("characterstatus")
}

enum PowerType {
  DISCIPLINE
  GIFT
  SPHERE
  EDGE
}

model PowerDefinition {
  id              String                 @id @default(uuid())
  name            String
  gameStyle       String // VAMPIRE, MAGE, WEREWOLF, HUNTER, UNIVERSAL
  type            PowerType
  description     String?                @db.Text
  powerLevels     PowerLevelDefinition[]
  characterPowers CharacterPower[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([name, gameStyle])
  @@map("powerdefinition")
}

model PowerLevelDefinition {
  id                  String                    @id @default(uuid())
  powerDefinitionId   String
  powerDefinition     PowerDefinition           @relation(fields: [powerDefinitionId], references: [id], onDelete: Cascade)
  level               Int
  name                String
  description         String?                   @db.Text
  system              String?                   @db.Text // Cost, Dice Pool, etc.
  characterSelections CharacterPowerSelection[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([powerDefinitionId, level, name])
  @@map("powerleveldefinition")
}

model CharacterPower {
  id                String                    @id @default(uuid())
  characterId       String
  character         Character                 @relation(fields: [characterId], references: [id], onDelete: Cascade)
  powerDefinitionId String
  powerDefinition   PowerDefinition           @relation(fields: [powerDefinitionId], references: [id], onDelete: Cascade)
  level             Int                       @default(1)
  selections        CharacterPowerSelection[]

  @@unique([characterId, powerDefinitionId])
  @@map("characterpower")
}

model CharacterPowerSelection {
  id                     String               @id @default(uuid())
  characterPowerId       String
  characterPower         CharacterPower       @relation(fields: [characterPowerId], references: [id], onDelete: Cascade)
  powerLevelDefinitionId String
  powerLevelDefinition   PowerLevelDefinition @relation(fields: [powerLevelDefinitionId], references: [id], onDelete: Cascade)

  @@unique([characterPowerId, powerLevelDefinitionId])
  @@map("characterpowerselection")
}

enum MeritFlawType {
  MERIT
  FLAW
}

model MeritFlawDefinition {
  id              String               @id @default(uuid())
  name            String
  type            MeritFlawType
  gameStyle       String // "VAMPIRE", "MAGE", "UNIVERSAL", etc.
  
  points          Int?                 // O custo em pontos (Ex: 2, 3, 4)
  category        String?              // "Física", "Social", "Mental"
  apiEffect       Json?                // Campo nativo JSON para guardar a lógica do 'efeito_api'
  
  description     String?              @db.Text
  characterMerits CharacterMeritFlaw[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([name, gameStyle, type])
  @@map("meritflawdefinition")
}

model CharacterMeritFlaw {
  id          String              @id @default(uuid())
  characterId String
  character   Character           @relation(fields: [characterId], references: [id], onDelete: Cascade)
  meritFlawId String
  meritFlaw   MeritFlawDefinition @relation(fields: [meritFlawId], references: [id], onDelete: Cascade)
  points      Int                 @default(1)
  description String?             @db.Text

  @@unique([characterId, meritFlawId])
  @@map("charactermeritflaw")
}

model ItemDefinition {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?         @db.Text
  damageOrEffect String?
  concealment    String?
  availability   Int?
  value          Float           @default(0.0) // Nível de Recursos
  requirements   String? // Ex: "Força 4", "Mago"
  characterItems CharacterItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  @@map("itemdefinition")
}

model CharacterItem {
  id             String         @id @default(uuid())
  characterId    String
  character      Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemId         String
  itemDefinition ItemDefinition @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity       Int            @default(1)
  description    String?        @db.Text

  @@unique([characterId, itemId])
  @@map("characteritem")
}

model Region {
  id               String  @id @default(uuid())
  name             String
  level            Int // 1: País, 2: Estado, 3: Cidade, 4: Bairro, 5: Rua, 6: Residência
  description      String? @db.Text
  narrativeClimate String? @db.Text
  factionDomain    String? // Quem domina a região
  difficultyDomain Int? // Dificuldade do teste de domínio
  dangerLevel      Int     @default(1)

  parentRegionId String?
  parentRegion   Region?  @relation("RegionHierarchy", fields: [parentRegionId], references: [id])
  childRegions   Region[] @relation("RegionHierarchy")

  characterHavens CharacterHaven[]

  // Relacionamentos Many-to-Many do Ecossistema Vivo
  criminalities     RegionCriminality[]
  mediaVisibilities RegionMediaVisibility[]
  publicSecurities  RegionPublicSecurity[]
  wealths           RegionWealth[]
  demographics      RegionDemographic[] // Substitui a nova lógica populacional mantendo a antiga segura

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("region")
}

// ----- Tabelas de Perfil (Os "Tipos" das Coisas) -----

model DemographicProfile {
  id          String              @id @default(uuid())
  species     String // Ex: Humano, Vampiro, Mago, Lobisomem
  socialClass String // Ex: Alta, Média, Baixa
  profession  String // Ex: Guarda, Vendedor, Padre, Estudante
  description String?             @db.Text
  regions     RegionDemographic[]

  @@unique([species, socialClass, profession])
  @@map("demographicprofile")
}

model Criminality {
  id          String              @id @default(uuid())
  crimeType   String // Ex: Assalto, Tráfico, Corrupção
  severity    String // Ex: Alto, Médio, Baixo
  description String?             @db.Text
  regions     RegionCriminality[]
  @@map("criminality")
}

model MediaVisibility {
  id          String                  @id @default(uuid())
  mediaType   String // Ex: Jornal, Rede Social, Fofoca
  severity    String // Alto, Médio, Baixo
  description String?                 @db.Text
  regions     RegionMediaVisibility[]
  @@map("mediavisibility")
}

model PublicSecurity {
  id           String                 @id @default(uuid())
  securityType String // Ex: GCM, PM, Segurança Privada
  description  String?                @db.Text
  regions      RegionPublicSecurity[]
  @@map("publicsecurity")
}

model Wealth {
  id          String         @id @default(uuid())
  wealthType  String // Ex: Pobreza Extrema, Classe Média, Luxo
  description String?        @db.Text
  regions     RegionWealth[]
  @@map("wealth")
}

// ----- Tabelas Associativas (O Estado Atual da Região) -----

model RegionDemographic {
  regionId             String
  demographicProfileId String
  quantity             Int // Quantidade exata desse perfil na região

  region             Region             @relation(fields: [regionId], references: [id], onDelete: Cascade)
  demographicProfile DemographicProfile @relation(fields: [demographicProfileId], references: [id], onDelete: Cascade)

  @@id([regionId, demographicProfileId])
  @@map("regiondemographic")
}

model RegionCriminality {
  regionId       String
  criminalityId  String
  testDifficulty Int

  region      Region      @relation(fields: [regionId], references: [id], onDelete: Cascade)
  criminality Criminality @relation(fields: [criminalityId], references: [id], onDelete: Cascade)

  @@id([regionId, criminalityId])
  @@map("regioncriminality")
}

model RegionMediaVisibility {
  regionId          String
  mediaVisibilityId String
  testDifficulty    Int

  region          Region          @relation(fields: [regionId], references: [id], onDelete: Cascade)
  mediaVisibility MediaVisibility @relation(fields: [mediaVisibilityId], references: [id], onDelete: Cascade)

  @@id([regionId, mediaVisibilityId])
  @@map("regionmediavisibility")
}

model RegionPublicSecurity {
  regionId         String
  publicSecurityId String
  testDifficulty   Int

  region         Region         @relation(fields: [regionId], references: [id], onDelete: Cascade)
  publicSecurity PublicSecurity @relation(fields: [publicSecurityId], references: [id], onDelete: Cascade)

  @@id([regionId, publicSecurityId])
  @@map("regionpublicsecurity")
}

model RegionWealth {
  regionId       String
  wealthId       String
  testDifficulty Int

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  wealth Wealth @relation(fields: [wealthId], references: [id], onDelete: Cascade)

  @@id([regionId, wealthId])
  @@map("regionwealth")
}

model BackgroundDefinition {
  id                   String                @id @default(uuid())
  name                 String
  gameStyle            String
  description          String?               @db.Text
  characterBackgrounds CharacterBackground[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([name, gameStyle])
  @@map("backgrounddefinition")
}

model CharacterBackground {
  id           String               @id @default(uuid())
  characterId  String
  character    Character            @relation(fields: [characterId], references: [id], onDelete: Cascade)
  backgroundId String
  background   BackgroundDefinition @relation(fields: [backgroundId], references: [id], onDelete: Cascade)
  level        Int                  @default(1)

  @@unique([characterId, backgroundId])
  @@map("characterbackground")
}

model HavenDefinition {
  id                   String           @id @default(uuid())
  name                 String
  description          String?          @db.Text
  price                Float            @default(0.0)
  securityLevel        Int              @default(1)
  minionCapacity       Int              @default(0)
  allyCapacity         Int              @default(0)
  requiredBackgroundId String?
  characterHavens      CharacterHaven[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  @@map("havendefinition")
}

model CharacterHaven {
  id                String          @id @default(uuid())
  characterId       String
  character         Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  havenDefinitionId String
  havenDefinition   HavenDefinition @relation(fields: [havenDefinitionId], references: [id], onDelete: Cascade)
  regionId          String
  region            Region          @relation(fields: [regionId], references: [id])
  @@map("characterhaven")
}

// ----- Módulo de Aventuras Interativas (Livro-Jogo / Acervo M:N) -----

model Adventure {
  id          String           @id @default(uuid())
  name        String
  gameStyle   String           // VAMPIRE, MAGE, WEREWOLF, etc.
  objective   String?          @db.Text
  scenes      AdventureScene[] // Relacionamento M:N
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@map("adventure")
}

// Acervo de Cenas Independentes
model Scene {
  id              String           @id @default(uuid())
  sceneIdentifier String           @unique // Ex: "Cena01" (Globais ou usar uuid)
  title           String
  description     String           @db.Text
  imageUrl        String?          // Mídia visual (URL)
  audioUrl        String?          // Mídia sonora (URL/SFX)
  
  apiConsequences Json?            // Lógica para aplicar dano/fome no fim da cena
  
  adventures      AdventureScene[] // Aventuras que usam essa cena
  actions         SceneAction[]    // Ações disponíveis nesta cena
  
  // Relacionamentos inversos para os destinos das ações
  actionSuccesses SceneAction[]    @relation("ActionSuccess")
  actionFailures  SceneAction[]    @relation("ActionFailure")

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  @@map("scene")
}

// Acervo de Ações Genéricas/Específicas Independentes
model Action {
  id               String        @id @default(uuid())
  actionIdentifier String        @unique // Ex: "Acao01_01" ou "Atirar"
  focus            String        // Físico, Mental, Social
  text             String        @db.Text
  testStr          String        // Ex: "Destreza + Furtividade"
  difficulty       Int           @default(0) // Dificuldade em sucessos exigidos
  
  scenes           SceneAction[] // Cenas em que essa ação foi inserida

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  @@map("action")
}

// Tabela Associativa M:N (Adventure <-> Scene)
model AdventureScene {
  id          String    @id @default(uuid())
  adventureId String
  adventure   Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  sceneId     String
  scene       Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  // Ordem da cena dentro da aventura, caso queira carregar na interface
  order       Int       @default(0)

  @@unique([adventureId, sceneId])
  @@map("adventurescene")
}

// Tabela Associativa M:N (Scene <-> Action)
model SceneAction {
  id             String  @id @default(uuid())
  sceneId        String
  scene          Scene   @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  actionId       String
  action         Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  
  // O Segredo da Reutilização: Os destinos ficam na tabela de ligação!
  successSceneId String?
  successScene   Scene?  @relation("ActionSuccess", fields: [successSceneId], references: [id], onDelete: SetNull)
  
  failureSceneId String?
  failureScene   Scene?  @relation("ActionFailure", fields: [failureSceneId], references: [id], onDelete: SetNull)

  // Ordem de exibição dos botões na tela
  order          Int     @default(0)

  @@unique([sceneId, actionId])
  @@map("sceneaction")
}
